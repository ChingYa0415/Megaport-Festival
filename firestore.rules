rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isWhitelistedAdminEmail() ||
        (isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
    }

    function isWhitelistedAdminEmail() {
      return isSignedIn() &&
        request.auth.token.email_verified == true &&
        request.auth.token.email == 'angus09855069@gmail.com';
    }

    // 使用者資料：登入者可讀、本人可寫
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && request.auth.uid == userId;
    }

    // 勾選資料：登入者可讀寫
    match /selections/{performanceId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
    }

    // 節目資料：登入者可讀，僅管理者可寫
    match /performances/{performanceId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 管理者白名單：僅允許本人讀取，建立請透過 Console 手動建立文件
    match /admins/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if false;
    }

    // 系統公告：登入者可讀，僅管理者可寫
    match /system/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
